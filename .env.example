# Telegram Bot Token from @BotFather
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here

# Comma-separated Telegram IDs of bot administrators
ADMIN_IDS=111111111,222222222

# ACRCloud credentials (https://console.acrcloud.com)
ACR_HOST=identify-eu-west-1.acrcloud.com
ACR_ACCESS_KEY=your_access_key
ACR_ACCESS_SECRET=your_access_secret

# Path to SQLite database file
DB_PATH=bot_database.db

# Max video size to send through Telegram (in MB)
MAX_VIDEO_SIZE_MB=50

# OPTIONAL: only set this if ffmpeg is NOT already on your system PATH.
# Common on Windows if you didn't add ffmpeg's "bin" folder to PATH.
# Example: C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=
